{
    "extends": [
        "@commitlint/config-conventional"
    ],
    "rules": {
        "type-enum": [
            2,
            "always",
            [
                "feat",
                "fix",
                "refactor",
                "docs",
                "test",
                "chore",
                "perf"
            ]
        ],
        "subject-case": [
            2,
            "never",
            [
                "upper-case"
            ]
        ]
    }
}